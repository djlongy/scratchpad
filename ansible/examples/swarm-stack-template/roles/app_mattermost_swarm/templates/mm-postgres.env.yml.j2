{# env block for the mm-postgres service. Rendered at deploy time by
   app_swarm_stack via lookup('template', ...) so it can freely
   reference swarm_stack_secret_values / _names. The output must be a
   YAML mapping of string keys to string values. #}
POSTGRES_DB: "{{ mattermost_pg_db }}"
POSTGRES_USER: "{{ mattermost_pg_user }}"
POSTGRES_PASSWORD_FILE: /run/secrets/mm_pg_password
