{# Mattermost docker-stack file — rendered by app_swarm_stack via the
   app_mattermost_swarm wrapper.

     - mm-postgres: single replica, NFS-backed pgdata, pinned to one
                    worker. POSTGRES_PASSWORD_FILE points at a docker
                    secret (postgres natively reads *_FILE).
     - mm-app:      N replicas, default image entrypoint. Sensitive
                    settings (DB connection, salts) are rendered into
                    MM_* env vars at deploy time — mattermost can't
                    tolerate a read-only config.json mount, so we skip
                    the docker config and use env-var overrides.

   The values for env vars come from swarm_stack_secret_values, which
   the generic role populates from your ansible-vault YAML. The values
   live in raft (encrypted) inside the service spec, just like a
   secret would. #}

version: "3.9"

{# Networks and NFS-backed volumes are pre-created by app_swarm_stack
   (encrypted attachable overlay via docker_network; local-driver NFS
   volumes pre-mounted on every candidate worker via docker_volume +
   delegate_to). Stack just references them as external: true so swarm
   doesn't try to recreate or rebind them at deploy time. #}
networks:
  mm_overlay:
    name: mm_overlay
    external: true

volumes:
  mm_pgdata:
    name: mm_pgdata
    external: true
  mm_app_data:
    name: mm_app_data
    external: true

secrets:
  mm_pg_password:
    name: {{ swarm_stack_secret_names.mm_pg_password }}
    external: true

services:

  # ───────────────────────────────────────────────────────────────────────────
  # Postgres — pinned single replica, password from /run/secrets.
  # ───────────────────────────────────────────────────────────────────────────
  mm-postgres:
    image: postgres:15-alpine
    networks:
      - mm_overlay
    environment:
      POSTGRES_DB: "{{ mattermost_pg_db }}"
      POSTGRES_USER: "{{ mattermost_pg_user }}"
      POSTGRES_PASSWORD_FILE: /run/secrets/mm_pg_password
    secrets:
      - mm_pg_password
    volumes:
      - mm_pgdata:/var/lib/postgresql/data
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.role == worker
{% if mattermost_pg_pinned_node %}
          - node.hostname == {{ mattermost_pg_pinned_node }}
{% endif %}
      restart_policy:
        condition: any
        delay: 10s
      resources:
        limits:
          memory: 512M

  # ───────────────────────────────────────────────────────────────────────────
  # Mattermost app — default image entrypoint. MM_* env vars override
  # the image's bundled config.json at startup. Mattermost can still
  # mutate its in-image config.json on disk (writable container layer).
  # ───────────────────────────────────────────────────────────────────────────
  mm-app:
    image: {{ mattermost_image }}
    networks:
      - mm_overlay
    depends_on:
      - mm-postgres
    environment:
      MM_SQLSETTINGS_DRIVERNAME: postgres
      MM_SQLSETTINGS_DATASOURCE: "postgres://{{ mattermost_pg_user }}:{{ swarm_stack_secret_values.mm_pg_password }}@mm-postgres:5432/{{ mattermost_pg_db }}?sslmode=disable&connect_timeout=10&binary_parameters=yes"
      MM_SQLSETTINGS_ATRESTENCRYPTKEY: "{{ swarm_stack_secret_values.mm_at_rest_key }}"
      MM_FILESETTINGS_PUBLICLINKSALT: "{{ swarm_stack_secret_values.mm_public_link_salt }}"
      MM_SERVICESETTINGS_SITEURL: "{{ mattermost_site_url }}"
      MM_SERVICESETTINGS_LISTENADDRESS: ":8065"
      MM_SERVICESETTINGS_FORWARD80TO443: "false"
      MM_SERVICESETTINGS_TRUSTEDPROXYIPHEADER: "X-Forwarded-For"
      MM_TEAMSETTINGS_SITENAME: "Mattermost"
      MM_LOGSETTINGS_ENABLECONSOLE: "true"
      MM_LOGSETTINGS_CONSOLELEVEL: "INFO"
      MM_LOGSETTINGS_CONSOLEJSON: "true"
      TZ: {{ mattermost_timezone }}
    volumes:
      - mm_app_data:/mattermost/data
    ports:
      - target: 8065
        published: {{ mattermost_published_port }}
        protocol: tcp
        mode: ingress
    deploy:
      replicas: {{ mattermost_replicas }}
      placement:
        constraints:
{% for c in mattermost_app_placement_constraints %}
          - {{ c }}
{% endfor %}
        max_replicas_per_node: {{ mattermost_max_per_node }}
      update_config:
        # stop-first because max_replicas_per_node: 1 leaves no spare
        # slot — start-first would deadlock waiting for a free node.
        parallelism: 1
        delay: 30s
        order: stop-first
        failure_action: rollback
      restart_policy:
        condition: any
        delay: 15s
        max_attempts: 5
      resources:
        limits:
          memory: 1G
