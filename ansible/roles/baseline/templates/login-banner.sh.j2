# {{ ansible_managed }}
# Interactive login banner. Sourced by /etc/profile for login shells.
# Host FQDN + IP are baked at deploy; the logging-in user resolves at login.
printf '\n'
printf '============================================================\n'
printf '  Environment : %s\n' "{{ baseline_banner_env_label }}"
printf '  Host        : %s\n' "{{ baseline_banner_fqdn }}"
{% if baseline_banner_ip | length > 0 %}
printf '  IP          : %s\n' "{{ baseline_banner_ip }}"
{% endif %}
printf '  User        : %s\n' "${USER:-$(id -un)}"
{% if baseline_banner_message | length > 0 %}
printf '  Notice      : %s\n' "{{ baseline_banner_message }}"
{% endif %}
printf '============================================================\n'
printf '\n'
