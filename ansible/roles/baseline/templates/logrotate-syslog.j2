/var/log/cron
/var/log/maillog
/var/log/messages
/var/log/secure
/var/log/spooler {
    hourly
    rotate {{ baseline_logrotate_rotate_count }}
    maxage {{ baseline_logrotate_maxage_days }}
    maxsize {{ baseline_logrotate_syslog_maxsize }}
    missingok
    notifempty
    compress
    dateext
    dateformat -%Y%m%d%H
    sharedscripts
    su root root
    postrotate
        /usr/bin/systemctl kill -s HUP rsyslog.service >/dev/null 2>&1 || true
    endscript
}
