{# Renders the FreeIPA CA cert into a docker-config file mounted at
   mattermost_ldap_ca_cert_path inside mm-app, so Mattermost's LDAP
   client can verify the LDAPS handshake without InsecureSkipVerify
   (which the FIPS edition treats as a misconfig).

   Vault location is fully described by the role's own defaults so the
   template stays portable across inventories that don't define the
   shared vault_* vars (e.g. inventories/swarm/). #}
{{
  lookup(
    'community.hashi_vault.hashi_vault',
    'secret=' ~ mattermost_ldap_ca_cert_vault_mount
              ~ '/data/' ~ mattermost_ldap_ca_cert_vault_path
              ~ ':' ~ mattermost_ldap_ca_cert_vault_field
              ~ ' url=' ~ mattermost_ldap_ca_cert_vault_addr
  )
}}
