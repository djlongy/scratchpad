#!/bin/bash
{{ ansible_managed | comment }}
# hashicorp_vault — Raft snapshot backup.
# Runs on every node via a systemd timer, but ONLY the active Raft leader
# actually takes the snapshot (is_self), so exactly one snapshot is produced
# per schedule. The snapshot is taken inside the container and copied out to the
# (possibly NFS) backup dir on the host. Auth is a SCOPED periodic token (read on
# sys/storage/raft/snapshot), passed via the process ENV — never on argv.
set -euo pipefail

CONTAINER="{{ hashicorp_vault_name }}"
BACKUP_DIR="{{ hashicorp_vault_backup_dir }}"
RETENTION_DAYS="{{ hashicorp_vault_backup_retention_days }}"
TOKEN_FILE="{{ hashicorp_vault_backup_token_file }}"
LOG_FILE="/var/log/vault-container-backup.log"
TS="$(date +%Y%m%d-%H%M%S)"
SNAP_HOST="${BACKUP_DIR}/vault-snapshot-${TS}.snap"
SNAP_CTR="/tmp/vault-snapshot-${TS}.snap"

log() { echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"; }

# Classify this node. Vault unreachable or SEALED is a real fault (non-zero so
# systemd surfaces it); an unsealed STANDBY is a clean skip (only the leader
# snapshots). is_self is true only on the active node.
STATUS_JSON="$(docker exec "${CONTAINER}" vault status -format=json 2>/dev/null || true)"
if [ -z "${STATUS_JSON}" ]; then
    log "ERROR: Vault unreachable on this node"; exit 1
fi
if [ "$(echo "${STATUS_JSON}" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("sealed"))' 2>/dev/null)" = "True" ]; then
    log "ERROR: Vault is sealed on this node"; exit 1
fi
if [ "$(echo "${STATUS_JSON}" | python3 -c 'import sys,json; print(1 if json.load(sys.stdin).get("is_self") else 0)' 2>/dev/null)" != "1" ]; then
    log "not the active leader — skipping"; exit 0
fi

if [ ! -r "${TOKEN_FILE}" ]; then
    log "ERROR: no backup token at ${TOKEN_FILE} (re-run the role's backup phase)"; exit 1
fi
export VAULT_TOKEN
VAULT_TOKEN="$(cat "${TOKEN_FILE}")"

# Keep the periodic token alive (best-effort; the backup phase re-mints if it dies).
docker exec -e VAULT_TOKEN "${CONTAINER}" vault token renew >/dev/null 2>&1 \
    || log "WARN: backup token renew failed"

log "taking Raft snapshot -> ${SNAP_HOST}"
docker exec -e VAULT_TOKEN "${CONTAINER}" vault operator raft snapshot save "${SNAP_CTR}"
docker cp "${CONTAINER}:${SNAP_CTR}" "${SNAP_HOST}"
docker exec "${CONTAINER}" rm -f "${SNAP_CTR}" || true
chmod 0640 "${SNAP_HOST}"
if [ ! -s "${SNAP_HOST}" ]; then
    log "ERROR: snapshot file is empty"; exit 1
fi
log "snapshot saved ($(du -h "${SNAP_HOST}" | cut -f1))"

# Prune snapshots older than the retention window.
PRUNED="$(find "${BACKUP_DIR}" -maxdepth 1 -name 'vault-snapshot-*.snap' \
          -mtime "+${RETENTION_DAYS}" -print -delete | wc -l | tr -d ' ')"
if [ "${PRUNED}" -gt 0 ]; then
    log "pruned ${PRUNED} snapshot(s) older than ${RETENTION_DAYS} day(s)"
fi
log "backup complete"
