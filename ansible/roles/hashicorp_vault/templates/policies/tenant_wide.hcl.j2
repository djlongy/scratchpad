{{ ansible_managed | comment }}
# Tenant-WIDE policy for "{{ _t.tenant }}" — full access to EVERY environment mount
# of this tenant ({{ hashicorp_vault_kv_mount_prefix }}-{{ _t.tenant }}-*), for a
# tenant admin who manages all of their environments at once.
#
# kv-<tenant>-* is a TRAILING-glob requiring the literal prefix "kv-<tenant>-". Because
# tenant names are HYPHEN-FREE (preflight asserts it), this can never match another
# tenant's mount — a different hyphen-free name cannot reproduce that "-" boundary
# (kv-acme-* does NOT match kv-acmecorp-prod). Prefer the per-env policies
# (<tenant>-<env>) for automation; reserve this wide grant for human tenant admins.
path "{{ hashicorp_vault_kv_mount_prefix }}-{{ _t.tenant }}-*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}
