{{ ansible_managed | comment }}
# vault.hcl — vault_container
# Topology: {{ 'Raft HA across ' ~ vault_ctr_node_count ~ ' nodes' if vault_ctr_is_ha | bool else 'standalone (single server)' }}

storage "raft" {
  path    = "{{ vault_ctr_container_data_dir }}"
  node_id = "{{ inventory_hostname }}"
{% if vault_ctr_is_ha | bool %}
{% for node in vault_ctr_nodes %}
  retry_join {
    leader_api_addr     = "{{ vault_ctr_scheme }}://{{ hostvars[node].vault_ctr_advertise_addr | default(hostvars[node].ansible_host) }}:{{ vault_ctr_api_port }}"
{% if vault_ctr_tls_enabled | bool %}
    leader_ca_cert_file = "{{ vault_ctr_container_certs_dir }}/ca.crt"
{% endif %}
  }
{% endfor %}
{% endif %}
}

listener "tcp" {
  address         = "0.0.0.0:{{ vault_ctr_api_port }}"
  cluster_address = "0.0.0.0:{{ vault_ctr_cluster_port }}"
{% if vault_ctr_tls_enabled | bool %}
  tls_cert_file            = "{{ vault_ctr_container_certs_dir }}/vault.crt"
  tls_key_file             = "{{ vault_ctr_container_certs_dir }}/vault.key"
  tls_client_ca_file       = "{{ vault_ctr_container_certs_dir }}/ca.crt"
  tls_disable_client_certs = "true"
{% else %}
  tls_disable = "true"
{% endif %}
}

api_addr     = "{{ vault_ctr_scheme }}://{{ vault_ctr_advertise_addr }}:{{ vault_ctr_api_port }}"
cluster_addr = "{{ vault_ctr_scheme }}://{{ vault_ctr_advertise_addr }}:{{ vault_ctr_cluster_port }}"

ui            = {{ vault_ctr_ui | bool | lower }}
disable_mlock = {{ vault_ctr_disable_mlock | bool | lower }}
{% if vault_ctr_telemetry_enabled | bool %}

telemetry {
  prometheus_retention_time = "24h"
  disable_hostname          = true
}
{% endif %}

log_level  = "{{ vault_ctr_log_level }}"
log_format = "{{ vault_ctr_log_format }}"
