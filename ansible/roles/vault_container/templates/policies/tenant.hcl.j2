{{ ansible_managed | comment }}
# Tenant "{{ _t.tenant }}" in environment "{{ _t.env }}".
# Grants access to ONLY this tenant's slice of the {{ vault_ctr_kv_mount_prefix }}-{{ _t.env }} KV v2 mount.

# Secret data under the tenant's prefix.
path "{{ vault_ctr_kv_mount_prefix }}-{{ _t.env }}/data/{{ _t.tenant }}/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

# Metadata (versions, list, soft-delete) under the tenant's prefix.
path "{{ vault_ctr_kv_mount_prefix }}-{{ _t.env }}/metadata/{{ _t.tenant }}/*" {
  capabilities = ["read", "list", "delete"]
}

# Let the tenant list the top of their own subtree.
path "{{ vault_ctr_kv_mount_prefix }}-{{ _t.env }}/metadata/{{ _t.tenant }}" {
  capabilities = ["read", "list"]
}
