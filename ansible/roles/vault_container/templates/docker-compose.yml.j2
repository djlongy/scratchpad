{{ ansible_managed | comment }}
# docker-compose.yml — vault_container
# Bridge network with published ports: peers reach a node on <node>:{{ vault_ctr_api_port }}
# / :{{ vault_ctr_cluster_port }}. Portable across engines (host networking is
# unreliable on some — e.g. Colima/Docker Desktop).
#
# The container runs the stock entrypoint as root, which setcaps the vault
# binary for IPC_LOCK and drops to the in-image vault user (uid {{ vault_ctr_uid }}). Do NOT set
# `user:` + SKIP_SETCAP here — without the setcap step the entrypoint's mlock
# retry re-execs vault and the two processes collide on the API port.
services:
  {{ vault_ctr_name }}:
    image: {{ vault_ctr_image }}
    container_name: {{ vault_ctr_name }}
    restart: unless-stopped
    cap_add:
      - IPC_LOCK
    ports:
      - "{{ vault_ctr_api_port }}:{{ vault_ctr_api_port }}"
      - "{{ vault_ctr_cluster_port }}:{{ vault_ctr_cluster_port }}"
    environment:
      # Skip the entrypoint's recursive chown of the bind-mounted config/logs
      # dirs (we set ownership from Ansible) so re-runs stay idempotent. NOTE:
      # do NOT also set SKIP_SETCAP — setcap must run so IPC_LOCK works and the
      # entrypoint does not re-exec vault (which collides on the API port).
      SKIP_CHOWN: "1"
      VAULT_ADDR: "{{ vault_ctr_scheme }}://127.0.0.1:{{ vault_ctr_api_port }}"
{% if vault_ctr_tls_enabled | bool %}
      VAULT_CACERT: "{{ vault_ctr_container_certs_dir }}/ca.crt"
{% endif %}
    volumes:
      - {{ vault_ctr_config_dir }}:{{ vault_ctr_container_config_dir }}
      - {{ vault_ctr_data_dir }}:{{ vault_ctr_container_data_dir }}
{% if vault_ctr_tls_enabled | bool %}
      - {{ vault_ctr_certs_dir }}:{{ vault_ctr_container_certs_dir }}:ro
{% endif %}
      - {{ vault_ctr_logs_dir }}:{{ vault_ctr_container_logs_dir }}
    # `server` only — the image entrypoint auto-adds -config=/vault/config (the
    # dir). Passing an explicit -config too would load vault.hcl TWICE and the
    # second listener bind fails "address already in use".
    command: server
