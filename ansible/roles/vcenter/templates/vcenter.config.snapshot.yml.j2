# yamllint disable rule:line-length
# yamllint disable rule:indentation
# (machine-generated snapshot — valid YAML; list_style may use flow/JSON lines)
# ─────────────────────────────────────────────────────────────────────────────
# vSphere FULL export — re-importable dictionaries (segregated blast radius)
#   ansible-playbook ... 10_vm_vcenter.yml --tags export
#
# Source  : {{ _vcenter_export.meta.source }}
# Bundle  : {{ _vcenter_export.meta.bundle }}
# Counts  : {{ _vcenter_export.meta.counts | to_json }}
# Format  : format={{ vcenter_export_format | default('yaml') }}
#           list_style={{ vcenter_export_list_style | default('block') }}
{% if _vcenter_export.meta.skipped | default([]) | length > 0 %}
# SKIPPED : {{ _vcenter_export.meta.skipped | to_json }}
{% endif %}
# ─────────────────────────────────────────────────────────────────────────────
# IMPORT MAP
#   vcenter_config:      group_vars → --tags topology
#   vcenter_esxi_hosts:  group_vars → host day-2 gates (list of hostnames)
#   esxi_host_configs:   split into host_vars/<host>.yml as esxi_* vars
#                        → roles/esxi --tags networking,ntp,dns,ssh
#
# NOT captured (by design): credentials, Machine SSL private keys, SSO users.
# ─────────────────────────────────────────────────────────────────────────────
{% set _style = vcenter_export_list_style | default('block') %}
{% set _cfg = _vcenter_export_config %}
---
# ═══ Bundle: vCenter topology (roles/vcenter) ═══════════════════════════════
vcenter_config:
{% if _style == 'block' %}
{{ _cfg | to_pretty_yaml(
     indent=2,
     width=200,
     gap_depth=vcenter_export_pretty_gap_depth | default(2) | int,
     gap_blocks_only=vcenter_export_pretty_gap_blocks_only | default(true) | bool,
     sort_keys=false
   ) | indent(2, first=true) }}
{% else %}
{% if _cfg.datacenter is defined and _cfg.datacenter %}
  datacenter:
{{ _cfg.datacenter | to_nice_yaml(indent=2, width=160, sort_keys=false) | indent(4, first=true) }}
{% else %}
  datacenter: {}
{% endif %}
{% for key in ['clusters', 'hosts', 'vds', 'portgroups', 'resource_pools', 'folders', 'vds_hosts'] %}
{% set _items = _cfg[key] | default([]) %}
{% if _items | length > 0 %}
  {{ key }}:
{% for _item in _items %}
{% if _style == 'json' %}
    - {{ _item | to_json }}
{% else %}
{% set _flow = _item | to_yaml(default_flow_style=true, width=4096, sort_keys=false) | trim %}
    - {{ ('{ ' ~ _flow[1:-1] ~ ' }') if (_flow[:1] == '{' and _flow[-1:] == '}') else _flow }}
{% endif %}
{% endfor %}
{% else %}
  {{ key }}: []
{% endif %}

{% endfor %}
{% endif %}

# ═══ Bundle: ESXi host list for vcenter day-2 loops ═════════════════════════
vcenter_esxi_hosts:
{% for h in _vcenter_export_esxi_hosts | default([]) %}
{% if _style == 'json' %}
  - {{ h | to_json }}
{% elif _style == 'yaml_flow' %}
{% set _flow = h | to_yaml(default_flow_style=true, width=4096, sort_keys=false) | trim %}
  - {{ ('{ ' ~ _flow[1:-1] ~ ' }') if (_flow[:1] == '{' and _flow[-1:] == '}') else _flow }}
{% else %}
  - hostname: {{ h.hostname }}
{% endif %}
{% else %}
  []
{% endfor %}

# ═══ Bundle: per-host esxi_* vars (roles/esxi host_vars) ════════════════════
# Key = name as registered in vCenter. Copy each map into host_vars.
esxi_host_configs:
{% set _hosts = _vcenter_export_esxi_configs | default({}) %}
{% if _hosts | length == 0 %}
  {}
{% else %}
{% for host_key in _hosts.keys() | list | sort %}
{% set _hc = _hosts[host_key] %}
  "{{ host_key }}":
{# Nested host maps always use to_pretty_yaml (indented lists + gap_depth). #}
{{ _hc | to_pretty_yaml(
     indent=2,
     width=200,
     gap_depth=vcenter_export_pretty_gap_depth | default(2) | int,
     gap_blocks_only=vcenter_export_pretty_gap_blocks_only | default(true) | bool,
     sort_keys=false
   ) | indent(4, first=true) }}
{% endfor %}
{% endif %}
