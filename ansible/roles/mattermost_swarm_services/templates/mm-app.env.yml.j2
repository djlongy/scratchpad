{# env block for the mm-app service. Rendered at deploy time so the
   late-bound swarm_stack_secret_values are baked in. The values land
   in raft (encrypted) inside the service spec, just like a docker
   secret would. #}
MM_SQLSETTINGS_DRIVERNAME: postgres
MM_SQLSETTINGS_DATASOURCE: "postgres://{{ mattermost_pg_user }}:{{ swarm_stack_secret_values.mm_pg_password }}@mm-postgres:5432/{{ mattermost_pg_db }}?sslmode=disable&connect_timeout=10&binary_parameters=yes"
MM_SQLSETTINGS_ATRESTENCRYPTKEY: "{{ swarm_stack_secret_values.mm_at_rest_key }}"
MM_FILESETTINGS_PUBLICLINKSALT: "{{ swarm_stack_secret_values.mm_public_link_salt }}"
MM_SERVICESETTINGS_SITEURL: "{{ mattermost_site_url }}"
MM_SERVICESETTINGS_LISTENADDRESS: ":8065"
MM_SERVICESETTINGS_FORWARD80TO443: "false"
MM_SERVICESETTINGS_TRUSTEDPROXYIPHEADER: "X-Forwarded-For"
MM_TEAMSETTINGS_SITENAME: "Mattermost"
MM_LOGSETTINGS_ENABLECONSOLE: "true"
MM_LOGSETTINGS_CONSOLELEVEL: "INFO"
MM_LOGSETTINGS_CONSOLEJSON: "true"
TZ: "{{ mattermost_timezone }}"
