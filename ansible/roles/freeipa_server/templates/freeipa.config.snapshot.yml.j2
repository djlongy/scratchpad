---
# yamllint disable rule:indentation
# (machine-generated: block sequences are emitted flush with their key; the
#  document is valid YAML and loads correctly — only the cosmetic indent-
#  sequences style differs. Re-indent by hand if you prefer once adopted.)
# ─────────────────────────────────────────────────────────────────────────────
# FreeIPA configuration snapshot — generated by the freeipa_server role
#   ansible-playbook ... freeipa.yml --tags export
#
# Source  : {{ _freeipa_export.meta.source }}  (realm {{ _freeipa_export.meta.realm }})
# Captured: {{ _freeipa_export.meta.captured_at }}
# Counts  : {{ _freeipa_export.meta.counts | to_json }}
# ─────────────────────────────────────────────────────────────────────────────
# This file IS the freeipa_server role's declarative group_vars contract. Drop it
# into an inventory group_vars (e.g. inventories/<env>/group_vars/freeipa.yml, or
# rename to taste) to reapply the captured identity state idempotently with this
# role — no rebuild-from-scratch required.
#
# NOT captured (by design):
#   * user passwords / Kerberos keys  — unreadable, realm-salted
#   * POSIX uid/gid numbers           — IPA assigns on a rebuild (no ID collisions)
#   * hostgroup host rosters          — enrolment + automember repopulate them
#                                       (re-run with --include-host-membership to pin)
#   * global_policy password policy   — owned by FreeIPA itself
{% if _freeipa_export.meta.fallback_group_used %}#
# NOTE: one or more accounts (typically service users) had no group beyond the
# default — 'ipausers' is declared below so their membership references resolve.
{% endif %}
# Source realm/domain — set these on a fresh install to recreate the SAME realm.
# Remove/change them if you are reapplying into a differently-named realm.
freeipa_server_domain: {{ _freeipa_export.freeipa_server_domain }}
freeipa_server_realm: {{ _freeipa_export.freeipa_server_realm }}
{% if _freeipa_export.freeipa_idam_roles | length > 0 %}
# Roles matrix — a role is a named bundle of groups; users below reference roles
# instead of long group lists (derived by co-occurrence: groups always held by
# the same users bundle together). Lossless. Rename role-NN to meaningful names.
{% endif %}
{% if _freeipa_export.meta.roles_excluded_from_mining %}
# ── Held OUT of role-mining (matched freeipa_server_export_role_exclude) ─────
# SANITY CHECK, not config (commented out, not loaded). These groups ARE still
# exported and applied below — as DIRECT group memberships in freeipa_idam_groups
# and on the users — they are NOT dropped. They were only kept out of the
# synthetic role bundles, so this explains why a group isn't inside a role:
{% for pat, grps in _freeipa_export.meta.roles_excluded_from_mining.items() %}
#   /{{ pat }}/  →  {{ grps | join(', ') }}
{% endfor %}
{% endif %}
{% for key in ['freeipa_idam_groups', 'freeipa_idam_roles', 'freeipa_idam_users', 'freeipa_idam_hostgroups', 'freeipa_idam_hbacsvcs', 'freeipa_idam_hbac_rules', 'freeipa_idam_sudo_commands', 'freeipa_idam_sudo_rules', 'freeipa_idam_pwpolicies', 'freeipa_server_automember_rules'] %}
{% if _freeipa_export[key] | length > 0 %}
{{ key }}:
{{ _freeipa_export[key] | to_nice_yaml(indent=2, width=160, sort_keys=False) | indent(2, first=True) }}
{% else %}
{{ key }}: []
{% endif %}
{% endfor %}
