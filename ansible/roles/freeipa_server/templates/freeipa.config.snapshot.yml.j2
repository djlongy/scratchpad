---
# yamllint disable rule:indentation
# (machine-generated: block sequences are emitted flush with their key; the
#  document is valid YAML and loads correctly — only the cosmetic indent-
#  sequences style differs. Re-indent by hand if you prefer once adopted.)
# ─────────────────────────────────────────────────────────────────────────────
# FreeIPA configuration snapshot — generated by the freeipa_server role
#   ansible-playbook ... freeipa.yml --tags export
#
{% set _fexport_scoped = (freeipa_server_export_scope | default([]) | length) > 0 %}
# Source  : {{ _freeipa_export.meta.source }}  (realm {{ _freeipa_export.meta.realm }})
# Captured: {{ _freeipa_export.meta.captured_at }}
# Counts  : {{ _freeipa_export.meta.counts | to_json }}
{% if _freeipa_export.meta.skipped | default([]) | length > 0 %}
# SKIPPED : {{ _freeipa_export.meta.skipped | to_json }}
#   ^ these sections could NOT be captured on this server (unavailable plugin /
#     command error) and are EMPTY below — not necessarily empty on the realm!
{% endif %}
# Export scope this snapshot was captured with (recorded below as real vars).
{% if _fexport_scoped and (freeipa_server_export_scope_mode | default('include')) == 'exclude' %}
#   OUTLIERS slice: objects whose name matches NONE of the scopes — the shared/
#   global set (users, DNS, built-ins). Each tenant/env's objects are in their own files.
{% elif _fexport_scoped %}
#   ONE tenant/env slice: only objects whose name contains a scope. NOT here by
#   design — users, DNS, built-ins, other tenants (they live in their own slices).
{% else %}
#   Full snapshot — every captured object.
{% endif %}
# These are EXPORT-time vars (inert when applying this file). A future
# `--tags export` from an inventory holding them re-uses this scope; override with
# -e freeipa_server_export_scope=[] for a full re-export.
freeipa_server_export_scope: {{ freeipa_server_export_scope | default([]) | to_json }}
freeipa_server_export_scope_mode: {{ freeipa_server_export_scope_mode | default('include') }}
# ─────────────────────────────────────────────────────────────────────────────
# This file IS the freeipa_server role's declarative group_vars contract. Drop it
# into an inventory group_vars (e.g. inventories/<env>/group_vars/freeipa.yml, or
# rename to taste) to reapply the captured identity state idempotently with this
# role — no rebuild-from-scratch required.
#
# NOT captured (by design):
#   * user passwords / Kerberos keys  — unreadable, realm-salted
#   * POSIX uid/gid numbers           — IPA assigns on a rebuild (no ID collisions)
#   * hostgroup host rosters          — enrolment + automember repopulate them
#                                       (re-run with --include-host-membership to pin)
#   * global_policy password policy   — owned by FreeIPA itself
{% if _freeipa_export.meta.fallback_group_used %}#
# NOTE: one or more accounts (typically service users) had no group beyond the
# default — 'ipausers' is declared below so their membership references resolve.
{% endif %}
{% if not _fexport_scoped %}
# Source realm/domain — set these on a fresh install to recreate the SAME realm.
# Remove/change them if you are reapplying into a differently-named realm.
freeipa_server_domain: {{ _freeipa_export.freeipa_server_domain }}
freeipa_server_realm: {{ _freeipa_export.freeipa_server_realm }}

# freeipa_server_fqdn is PER-HOST — the role derives it (inventory_hostname + domain).
# Captured value kept for reference only; NEVER uncomment in a multi-host group file
# (it would rename every other host in the group to this one on install).
# freeipa_server_fqdn: {{ _freeipa_export.freeipa_server_fqdn }}

# Upstream DNS forwarder(s) for the IPA-managed zone (captured from THIS server's
# dnsserver config — forwarders live per-server, not in the global dnsconfig).
# Empty list = no integrated DNS forwarding on this server.
freeipa_server_forwarders: {{ _freeipa_export.freeipa_server_forwarders | to_json }}
freeipa_server_forward_policy: {{ _freeipa_export.freeipa_server_forward_policy }}
{% else %}
# Scoped slice (freeipa_server_export_scope active) — server identity
# (realm/domain/fqdn/forwarders) is intentionally omitted; it belongs on the IPA
# host's own group_vars, not a per-tenant/env file.
{% endif %}
#
# HOST-LEVEL networking — NOT FreeIPA state, so it cannot be captured here. Set it
# per host in inventory (host_vars/group_vars), not in this snapshot:
#   connection_name: eth0   # NetworkManager connection name (used by replica DNS prep)
#
# Users below carry their REAL, literal `groups` exactly as held in FreeIPA — this
# snapshot is a faithful mirror of the directory, not an inferred refactor.
{% set _fexport_style = freeipa_server_export_list_style | default('yaml_flow') %}
{% for key in ['freeipa_iam_usergroups', 'freeipa_iam_users', 'freeipa_iam_service_accounts', 'freeipa_iam_hostgroups', 'freeipa_iam_iparoles', 'freeipa_iam_privileges', 'freeipa_iam_permissions', 'freeipa_iam_hbacsvcs', 'freeipa_iam_hbacsvcgroups', 'freeipa_iam_hbac_rules', 'freeipa_iam_sudo_commands', 'freeipa_iam_sudocmdgroups', 'freeipa_iam_sudo_rules', 'freeipa_iam_pwpolicies', 'freeipa_server_dns_zones', 'freeipa_server_dns_forward_zones', 'freeipa_server_dns_records', 'freeipa_server_automember_rules'] %}
{% if _freeipa_export[key] | length > 0 %}
{% if _fexport_style in ['json', 'yaml_flow'] %}
{{ key }}:
{% for _item in _freeipa_export[key] %}
{% if _fexport_style == 'json' %}
  - {{ _item | to_json }}
{% else %}
{% set _flow = _item | to_yaml(default_flow_style=True, width=4096, sort_keys=False) | trim %}
  - {{ ('{ ' ~ _flow[1:-1] ~ ' }') if (_flow[:1] == '{' and _flow[-1:] == '}') else _flow }}
{% endif %}
{% endfor %}
{% else %}
{{ key }}:
{{ _freeipa_export[key] | to_nice_yaml(indent=2, width=160, sort_keys=False) | indent(2, first=True) }}
{% endif %}
{% else %}
{{ key }}: []
{% endif %}
{# blank line between each root-key block for readability #}

{% endfor %}
